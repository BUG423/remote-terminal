{
  "_comment": "=== Claude Web 配置文件 ===",
  "_instructions": "复制此文件为 config.json 并填入你的信息: cp config.json.example config.json",

  "port": 3002,
  "_port_comment": "服务器监听端口，默认 3002",

  "bindHost": "127.0.0.1",
  "_bindHost_comment": "监听地址。配合 Nginx 反向代理时设为 127.0.0.1（不对外暴露端口）；直接对外服务时设为 0.0.0.0",

  "tokens": {
    "your-token-for-agent-1-change-me": "办公室电脑",
    "your-token-for-agent-2-change-me": "家里笔记本"
  },
  "_tokens_comment": "多 Agent Token 映射（推荐）。每个 Agent 使用独立 Token，浏览器输入哪个 Token 就连到哪个 Agent。生成 Token: node -e \"console.log(require('crypto').randomBytes(24).toString('base64url'))\"",

  "token": "DEPRECATED-use-tokens-instead",
  "_token_comment": "【已废弃】单 Token 模式。仅用于兼容旧版。建议使用上面的 tokens 替代。",

  "serverHost": "your-server-ip-or-domain",
  "_serverHost_comment": "云服务器的公网 IP 地址或域名。Agent 和浏览器都将连接到此地址。",

  "serverPort": 3000,
  "_serverPort_comment": "云服务器上 Nginx 对外暴露的端口。Agent 和浏览器都连接这个端口，Nginx 再反向代理到内部的 port (3002)。",

  "useTLS": false,
  "_useTLS_comment": "【直连模式】是否由 Node.js 直接处理 TLS。Nginx 反向代理时设为 false，Agent 通过 CW_USE_WSS=true 环境变量启用 WSS。本地测试可设为 true + scripts/generate-cert.sh 自签名证书。",

  "tlsCertPath": "/etc/letsencrypt/live/your-domain.com/fullchain.pem",
  "tlsKeyPath": "/etc/letsencrypt/live/your-domain.com/privkey.pem",
  "_tls_comment": "TLS 证书路径，仅在 useTLS=true 时需要。Nginx 模式下证书由 Nginx 管理（certbot --nginx），此处无需配置。",

  "redirectPort": 80,
  "_redirectPort_comment": "HTTP→HTTPS 重定向端口，仅在 useTLS=true 时生效。Nginx 模式下重定向由 Nginx 处理，此处可忽略。",

  "workspaceRoot": "~/WebClaudeWorkspaces",
  "_workspaceRoot_comment": "【Agent 端】工作区根目录。所有会话在此目录下启动，用户可在终端中自行创建文件夹。所有会话被强制限制在此根目录内（安全边界）。支持 ~ 展开。"
}
