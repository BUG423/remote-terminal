{
  "_comment": "=== Remote Terminal 配置文件 ===",
  "_instructions": "复制为 config.json；替换所有 change-me/example.com 示例值，不要提交 config.json",

  "port": 3002,
  "bindHost": "127.0.0.1",
  "_server_listen_comment": "Server 只监听本机 3002，由 Nginx 在 443 提供 HTTPS/WSS",

  "devices": {
    "server-a": {
      "name": "受控服务器 A",
      "browserToken": "change-me-browser-random-token-01",
      "agentToken": "change-me-agent-random-token-02"
    }
  },
  "_devices_comment": "每台设备使用彼此不同的浏览器和 Agent Token，防止浏览器凭据伪装 Agent",

  "agentToken": "change-me-agent-random-token-02",
  "_agent_token_comment": "Agent 使用 devices 中对应的 agentToken；也可用 CLAUDE_WEB_TOKEN 覆盖",

  "serverUrl": "wss://terminal.example.com",
  "_server_url_comment": "Agent 主动连接的完整地址，推荐 WSS 443，可带路径。CW_SERVER_URL 可覆盖",

  "proxyUrl": "",
  "noProxy": "localhost,127.0.0.1",
  "_proxy_comment": "可选 HTTP/HTTPS 出口代理；也支持 HTTPS_PROXY、HTTP_PROXY 和 NO_PROXY",

  "workspaceRoot": "~/WebClaudeWorkspaces",
  "_workspace_root_comment": "Agent 终端的起始目录。Shell 仍可访问运行用户有权限访问的其他路径，这不是系统沙箱",

  "maxSessions": 12,
  "maxBrowsersPerToken": 8,
  "maxTotalConnections": 200,
  "maxWsBufferedBytes": 2097152,
  "scrollbackBytes": 262144,
  "offlineOutputBytes": 262144,
  "_limits_comment": "限制每个 Agent 的 PTY 数、浏览器连接数，以及 Server/Agent 每会话输出缓存",

  "auditEnabled": true,
  "auditLogPath": "~/WebClaudeWorkspaces/.audit.log",
  "auditMaxBytes": 10485760,
  "_audit_comment": "审计日志默认 0600 权限并自动轮转；日志可能包含输入的敏感命令，可按风险关闭",

  "enableLegacyChat": false,
  "claudeDangerouslySkipPermissions": false,
  "_legacy_chat_comment": "旧 claude -p 聊天协议默认关闭；即使启用也默认保留 Claude 权限确认",

  "useTLS": false,
  "tlsCertPath": "/etc/letsencrypt/live/terminal.example.com/fullchain.pem",
  "tlsKeyPath": "/etc/letsencrypt/live/terminal.example.com/privkey.pem",
  "redirectPort": 80,
  "_direct_tls_comment": "仅 Node.js 直连 TLS 时使用。推荐由 Nginx 处理 TLS，因此保持 false",

  "serverHost": "",
  "serverPort": 3002,
  "_legacy_connection_comment": "serverHost/serverPort 仅兼容旧 Agent 配置；设置 serverUrl 后忽略"
}
